# ─── UltraOrça Instagram Auto-Post ───────────────────────────────────────────
# Copie este arquivo para carousels/.env e preencha os valores.
# O arquivo .env NUNCA deve ser commitado no Git.

# ID numérico da sua conta Instagram Business
# Como obter: veja carousels/SETUP.md passo 3
IG_USER_ID=

# Token de acesso de longa duração do Meta (válido 60 dias)
# Como obter: veja carousels/SETUP.md passo 3
META_ACCESS_TOKEN=

# URL do seu projeto Supabase (ex: https://abcdef.supabase.co)
SUPABASE_URL=

# Service Role Key do Supabase (Settings → API → service_role)
# NUNCA exponha essa chave no frontend — só use localmente
SUPABASE_SERVICE_KEY=
